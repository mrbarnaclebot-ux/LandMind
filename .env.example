# =============================================================================
# LandMind Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Connection string for PostgreSQL database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://landmind:your_password_here@localhost:5433/landmind?schema=public"

# -----------------------------------------------------------------------------
# Cache (Redis)
# -----------------------------------------------------------------------------
# Connection string for Redis cache and pub/sub
# Format: redis://HOST:PORT
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port the backend server listens on
PORT=3001

# Environment mode (development, staging, production)
NODE_ENV=development

# JWT secret for session tokens (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-at-least-32-chars"

# Allowed CORS origin for frontend
CORS_ORIGIN="http://localhost:5173"

# -----------------------------------------------------------------------------
# Solana Configuration
# -----------------------------------------------------------------------------
# RPC endpoint for Solana network
# Devnet: https://api.devnet.solana.com
# Mainnet: https://api.mainnet-beta.solana.com (or your preferred RPC)
SOLANA_RPC_URL="https://api.devnet.solana.com"

# Helius RPC URL for DAS API (required for cNFT operations)
# Get your API key at: https://helius.dev
HELIUS_RPC_URL="https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY"

# Server wallet secret key for signing transactions
# Format: JSON array of bytes, e.g., [123,45,67,...]
# Generate a new wallet: solana-keygen new --outfile server-wallet.json
# Then copy the contents here as a single line
SERVER_WALLET_SECRET="[your,server,wallet,secret,key,bytes]"

# Merkle tree address for compressed NFT minting
# Create one using: npx @metaplex-foundation/mpl-bubblegum-cli create-tree
MERKLE_TREE_ADDRESS="your-merkle-tree-pubkey"

# -----------------------------------------------------------------------------
# Admin Configuration (Optional)
# -----------------------------------------------------------------------------
# Wallet public keys that should have admin access
# Users with these wallets are auto-promoted to ADMIN role on login
ADMIN_WALLET_1="admin-wallet-pubkey-1"
# ADMIN_WALLET_2="admin-wallet-pubkey-2"
# ADMIN_WALLET_3="admin-wallet-pubkey-3"

# -----------------------------------------------------------------------------
# PumpFun Integration (Optional)
# -----------------------------------------------------------------------------
# Fee wallet address to monitor for PumpFun trading fees
# Leave empty to disable PumpFun fee monitoring
PUMPFUN_FEE_WALLET=""

# -----------------------------------------------------------------------------
# Client Configuration (packages/client/.env)
# -----------------------------------------------------------------------------
# These variables should be in packages/client/.env, not here
# They are listed for reference:
#
# VITE_API_URL="http://localhost:3001"
# VITE_WS_URL="http://localhost:3001"
# VITE_SOLANA_RPC_URL="https://api.devnet.solana.com"
# VITE_HEX_GRID_RADIUS="20"
