# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://landmind:landmind@localhost:5433/landmind?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Solana RPC
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# Metaplex/cNFT Configuration
# Helius RPC provides DAS API for fetching cNFTs
# Get API key at: https://dev.helius.xyz/dashboard
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Server wallet for signing mints (base58-encoded secret key)
# Generate: solana-keygen new --outfile keypair.json
# Encode: cat keypair.json | npx tsx -e "console.log(require('bs58').encode(JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'))))"
SERVER_WALLET_SECRET=your_base58_encoded_secret_key

# Merkle tree address for cNFT storage
# Created by running: npx tsx scripts/createMerkleTree.ts
MERKLE_TREE_ADDRESS=created_tree_pubkey

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
