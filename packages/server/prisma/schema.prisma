// Source: Adapted from Prisma data modeling docs
// packages/server/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  walletPubkey String @unique @map("wallet_pubkey")
  role      UserRole @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  agents    Agent[]
  claims    Claim[]
  earningsSnapshot EarningsSnapshot?

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

model Agent {
  id           String   @id @default(uuid())
  owner        User     @relation(fields: [ownerId], references: [id])
  ownerId      String   @map("owner_id")
  hexId        Int?     @map("hex_id")
  hex          Hex?     @relation(fields: [hexId], references: [id])
  status       AgentStatus @default(IDLE)
  deployedAt   DateTime @default(now()) @map("deployed_at")
  // Phase B (Weather): last time this agent was manually relocated by its owner.
  // Enforces the 10-min relocation cooldown. Null = never relocated (no cooldown).
  lastRelocatedAt DateTime? @map("last_relocated_at")
  miningState  MiningState?

  // cNFT fields - added for Phase 5
  mintAddress     String?  @unique @map("mint_address")  // cNFT asset ID
  deployTxSig     String?  @unique @map("deploy_tx_sig")  // Deployment transaction signature (unique to prevent reuse)
  mintTxSig       String?  @map("mint_tx_sig")           // Minting transaction signature
  agentIndex      Int?     @map("agent_index")           // On-chain index from event

  @@map("agents")
}

model Hex {
  id             Int      @id @default(autoincrement())
  q              Int      // Axial coordinate
  r              Int      // Axial coordinate
  resourceType   ResourceType @map("resource_type")
  resourceAmount BigInt   @default(1000000) @map("resource_amount")
  elevation      Int      @default(0)   // Visual terrain tier 0..6 (from client terrain generator)
  isDeep         Boolean  @default(false) // Pit floor OR cave-mouth-adjacent hex — "deep" night real estate
  // Phase B (Weather): biome band from the client generator's getBiome (single
  // source of truth). Drives the per-front weather yield modifier (weatherTable).
  // Populated by scripts/syncTerrain.ts; GRASSLAND default keeps existing rows valid.
  biome          Biome    @default(GRASSLAND)
  currentAgent   Agent[]

  @@unique([q, r])
  @@index([q, r])
  @@map("hexes")
}

model MiningState {
  id         String   @id @default(uuid())
  agent      Agent    @relation(fields: [agentId], references: [id])
  agentId    String   @unique @map("agent_id")
  gold       BigInt   @default(0)
  silver     BigInt   @default(0)
  copper     BigInt   @default(0)
  iron       BigInt   @default(0)
  lastUpdate DateTime @default(now()) @map("last_update")

  @@map("mining_states")
}

enum AgentStatus {
  IDLE
  MINING
  RELOCATING
}

enum ResourceType {
  GOLD
  SILVER
  COPPER
  IRON
  EMPTY
}

// Biome bands — mirror the client terrain generator's Biome type (getBiome).
// Server-side source for the Phase B weather modifier table (weatherTable).
enum Biome {
  GRASSLAND
  MARSH
  PLAINS
  FOREST
  ROCKY
  ALPINE
}

enum FeeSource {
  DEPLOYMENT
  PUMPFUN
}

model FeeDeposit {
  id          String    @id @default(uuid())
  txSignature String    @unique @map("tx_signature")
  amount      BigInt    // lamports
  source      FeeSource
  depositedAt DateTime  @default(now()) @map("deposited_at")
  processed   Boolean   @default(false)

  @@map("fee_deposits")
}

model Claim {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @map("user_id")
  amount      BigInt   // lamports claimed
  txSignature String   @unique @map("tx_signature")
  claimedAt   DateTime @default(now()) @map("claimed_at")

  @@map("claims")
}

model EarningsSnapshot {
  id            String    @id @default(uuid())
  user          User      @relation(fields: [userId], references: [id])
  userId        String    @unique @map("user_id")
  weightedScore BigInt    @map("weighted_score")
  totalClaimed  BigInt    @default(0) @map("total_claimed")
  lastClaimAt   DateTime? @map("last_claim_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("earnings_snapshots")
}

model EconomyConfig {
  id              String    @id @default("default")
  minClaimAmount  BigInt    @default(25000000) @map("min_claim_amount")  // 0.025 SOL
  goldWeight      Int       @default(4000) @map("gold_weight")
  silverWeight    Int       @default(2000) @map("silver_weight")
  copperWeight    Int       @default(1500) @map("copper_weight")
  ironWeight      Int       @default(1000) @map("iron_weight")
  isPaused        Boolean   @default(false) @map("is_paused")
  pausedAt        DateTime? @map("paused_at")
  pausedBy        String?   @map("paused_by")  // Admin wallet who paused
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("economy_config")
}
