// Source: Adapted from Prisma data modeling docs
// packages/server/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  walletPubkey String @unique @map("wallet_pubkey")
  role      UserRole @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  // Phase C (Hazards): throttled (≤1/min) last-seen timestamp. Cave-ins only
  // fire on agents whose owner was active within the last 60 min (offline grace).
  lastActiveAt DateTime? @map("last_active_at")
  // Phase D (Engagement): resume-not-reset daily-contract streak. NEVER resets on
  // a missed day (design System 4 — Egg Inc calendar model). Increments by 1 each
  // day the user completes their contract.
  contractStreak Int    @default(0) @map("contract_streak")
  // Phase D (Seasons): permanent additive per-season yield bonus (+0.02 per closed
  // season the user participated in). Joins the tick-loop yield product as
  // (1 + seasonBonusPct). Never a hard wipe (design anti-pattern rule 7).
  seasonBonusPct Float  @default(0) @map("season_bonus_pct")
  agents    Agent[]
  claims    Claim[]
  earningsSnapshot EarningsSnapshot?
  contracts Contract[]
  surveys   Survey[]
  seasonResults SeasonResult[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

model Agent {
  id           String   @id @default(uuid())
  owner        User     @relation(fields: [ownerId], references: [id])
  ownerId      String   @map("owner_id")
  hexId        Int?     @map("hex_id")
  hex          Hex?     @relation(fields: [hexId], references: [id])
  status       AgentStatus @default(IDLE)
  deployedAt   DateTime @default(now()) @map("deployed_at")
  // Phase B (Weather): last time this agent was manually relocated by its owner.
  // Enforces the 10-min relocation cooldown. Null = never relocated (no cooldown).
  lastRelocatedAt DateTime? @map("last_relocated_at")
  // Phase C (Hazards): equipment wear ∈ [0,1]. Accrues only while actively mining
  // (never idle-time decay); efficiency = 1 - 0.3*wear. Repair resets to 0.
  wear         Float    @default(0)
  // Cave-in state (System 3). trappedAt = when it fired; selfDigAt = when the
  // agent auto-frees. Both NULL unless status === TRAPPED. Never confiscatory.
  trappedAt    DateTime? @map("trapped_at")
  selfDigAt    DateTime? @map("self_dig_at")
  miningState  MiningState?

  // cNFT fields - added for Phase 5
  mintAddress     String?  @unique @map("mint_address")  // cNFT asset ID
  deployTxSig     String?  @unique @map("deploy_tx_sig")  // Deployment transaction signature (unique to prevent reuse)
  mintTxSig       String?  @map("mint_tx_sig")           // Minting transaction signature
  agentIndex      Int?     @map("agent_index")           // On-chain index from event

  @@map("agents")
}

model Hex {
  id             Int      @id @default(autoincrement())
  q              Int      // Axial coordinate
  r              Int      // Axial coordinate
  resourceType   ResourceType @map("resource_type")
  resourceAmount BigInt   @default(1000000) @map("resource_amount")
  elevation      Int      @default(0)   // Visual terrain tier 0..6 (from client terrain generator)
  isDeep         Boolean  @default(false) // Pit floor OR cave-mouth-adjacent hex — "deep" night real estate
  // Phase B (Weather): biome band from the client generator's getBiome (single
  // source of truth). Drives the per-front weather yield modifier (weatherTable).
  // Populated by scripts/syncTerrain.ts; GRASSLAND default keeps existing rows valid.
  biome          Biome    @default(GRASSLAND)
  currentAgent   Agent[]

  @@unique([q, r])
  @@index([q, r])
  @@map("hexes")
}

model MiningState {
  id         String   @id @default(uuid())
  agent      Agent    @relation(fields: [agentId], references: [id])
  agentId    String   @unique @map("agent_id")
  gold       BigInt   @default(0)
  silver     BigInt   @default(0)
  copper     BigInt   @default(0)
  iron       BigInt   @default(0)
  lastUpdate DateTime @default(now()) @map("last_update")

  @@map("mining_states")
}

enum AgentStatus {
  IDLE
  MINING
  RELOCATING
  // Phase C (Hazards): caught in a cave-in — stops mining until Rescue or the
  // 4-hour self-dig timer. Already-mined resources are never confiscated.
  TRAPPED
}

enum ResourceType {
  GOLD
  SILVER
  COPPER
  IRON
  EMPTY
}

// Biome bands — mirror the client terrain generator's Biome type (getBiome).
// Server-side source for the Phase B weather modifier table (weatherTable).
enum Biome {
  GRASSLAND
  MARSH
  PLAINS
  FOREST
  ROCKY
  ALPINE
}

enum FeeSource {
  DEPLOYMENT
  PUMPFUN
}

model FeeDeposit {
  id          String    @id @default(uuid())
  txSignature String    @unique @map("tx_signature")
  amount      BigInt    // lamports
  source      FeeSource
  depositedAt DateTime  @default(now()) @map("deposited_at")
  processed   Boolean   @default(false)

  @@map("fee_deposits")
}

model Claim {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @map("user_id")
  amount      BigInt   // lamports claimed
  txSignature String   @unique @map("tx_signature")
  claimedAt   DateTime @default(now()) @map("claimed_at")

  @@map("claims")
}

model EarningsSnapshot {
  id            String    @id @default(uuid())
  user          User      @relation(fields: [userId], references: [id])
  userId        String    @unique @map("user_id")
  weightedScore BigInt    @map("weighted_score")
  totalClaimed  BigInt    @default(0) @map("total_claimed")
  lastClaimAt   DateTime? @map("last_claim_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("earnings_snapshots")
}

model EconomyConfig {
  id              String    @id @default("default")
  minClaimAmount  BigInt    @default(25000000) @map("min_claim_amount")  // 0.025 SOL
  goldWeight      Int       @default(4000) @map("gold_weight")
  silverWeight    Int       @default(2000) @map("silver_weight")
  copperWeight    Int       @default(1500) @map("copper_weight")
  ironWeight      Int       @default(1000) @map("iron_weight")
  isPaused        Boolean   @default(false) @map("is_paused")
  pausedAt        DateTime? @map("paused_at")
  pausedBy        String?   @map("paused_by")  // Admin wallet who paused
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("economy_config")
}

// Phase D (Engagement) — daily per-user contract (System 4).
// One row per (user, UTC day). Generated lazily on GET /api/contracts and
// deterministic per (userId, dateUTC). Progress accumulates from the tick loop
// as the owner's agents mine the matching resource; on reaching target it is
// marked complete (completedAt set) and the user's contractStreak increments.
model Contract {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String   @map("user_id")
  // UTC calendar day this contract belongs to, 'YYYY-MM-DD'.
  dateUTC      String   @map("date_utc")
  resourceType ResourceType @map("resource_type")
  // Resource units required to complete (scaled to the user's agent count).
  target       BigInt
  // Resource units mined toward the target so far (flushed from Redis).
  progress     BigInt   @default(0)
  // When the contract was completed (NULL = still in progress).
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([userId, dateUTC])
  @@index([userId])
  @@map("contracts")
}

// Phase D (Engagement) — Prospecting / Survey (System 4).
// Durable per-user knowledge of a surveyed hex. One row per (user, q, r). The
// snapshot returned to the client always reads CURRENT hex data (join at read),
// so "surveyed" is a durable unlock, never a stale copy.
model Survey {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String   @map("user_id")
  q          Int
  r          Int
  surveyedAt DateTime @default(now()) @map("surveyed_at")

  @@unique([userId, q, r])
  @@index([userId])
  @@map("surveys")
}

// Phase D (Seasons) — soft-prestige snapshot (System 4).
// A season is closed manually (scripts/closeSeason.ts): the leaderboard ZSET is
// snapshotted into SeasonResult rows, the ZSET is reset, and every participant's
// seasonBonusPct increments by 0.02. Never a hard wipe (assets/agents carry over).
model Season {
  id        String   @id @default(uuid())
  number    Int      @unique
  closedAt  DateTime @default(now()) @map("closed_at")
  totalPool BigInt   @default(0) @map("total_pool")
  results   SeasonResult[]

  @@map("seasons")
}

model SeasonResult {
  id       String @id @default(uuid())
  season   Season @relation(fields: [seasonId], references: [id])
  seasonId String @map("season_id")
  user     User   @relation(fields: [userId], references: [id])
  userId   String @map("user_id")
  rank     Int
  score    BigInt

  @@unique([seasonId, userId])
  @@index([seasonId])
  @@map("season_results")
}
