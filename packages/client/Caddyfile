# Caddy config for the LandMind SPA.
# Railway injects PORT; default to 8080 for local runs.
{
	admin off
	auto_https off
}

:{$PORT:8080} {
	root * /srv
	encode gzip

	# SPA fallback: serve the requested file if it exists, otherwise index.html
	# so client-side routing works on deep links / refreshes.
	try_files {path} /index.html
	file_server

	# Basic hardening headers.
	header {
		-Server
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
	}
}
